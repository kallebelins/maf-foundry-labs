# =============================================================================
# Microsoft Agent Framework MCP - Git Ignore
# =============================================================================

# =============================================================================
# Environment and Secrets
# =============================================================================
# Environment files with sensitive configuration
.env
.env.*
*.env.local
*.env.*.local

# Keep the example file
!.env.example

# User secrets
secrets.json
appsettings.local.json
appsettings.Development.json
*.pfx
*.key
*.pem

# =============================================================================
# Node.js / TypeScript
# =============================================================================
node_modules/
dist/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo

# =============================================================================
# .NET Build Output
# =============================================================================
bin/
obj/
out/
[Bb]uild/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Ll]og/
[Ll]ogs/

# =============================================================================
# .NET Debug and Compiled Files
# =============================================================================
*.pdb
*.ilk
*.dll
*.exe
*.so
*.dylib

# =============================================================================
# IDE and Editor
# =============================================================================
# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.sln.DotSettings.user

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains Rider
.idea/
*.sln.iml

# =============================================================================
# NuGet
# =============================================================================
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# =============================================================================
